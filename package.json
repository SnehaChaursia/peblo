{
  "name": "peblo-ai-notes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite client --host 0.0.0.0",
    "build": "vite build client --outDir ../dist",
    "start": "node server/index.js",
    "smoke": "node scripts/smoke-test.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "nodemon": "^3.1.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "devDependencies": {}
}
